const UAS_HDLD_AMMOPOUCH = "apo";

enum AmmoPouchSlots {

	// From HDStorageItemStats
	// ------------------------

	// SISTAT_ININDEX  = 1,
	// SISTAT_SELINDEX = 2,
	// SISTAT_HOWMANY  = 3,
	// SISTAT_SCROLL   = 4,

	// SI_WEPICONSLOT  = HDWEP_STATUSSLOTS + 1,
	// SI_WEPBULKSLOT  = HDWEP_STATUSSLOTS + 2,
	// SI_MAXROWS      = 10,
	// SI_MAXBUNCH     = 20,
	// SI_SCROLLCYCLE  = (2 << 9),

	APS_AMOUNT         = 5
}

//==================================================
// Base Definition
//==================================================
class UaS_AmmoPouch : HDStorageItem {

	default {
		+Inventory.INVBAR
		+Weapon.WIMPY_WEAPON
		// -HDWeapon.DROPTRANSLATION
		+HDWeapon.FITSINBACKPACK
		// +HDWeapon.IGNORELOADOUTAMOUNT

		Tag "$TAG_AMMOPOUCH";
		Inventory.Icon "UGSPA0";
		Inventory.PickupMessage "$PICKUP_AMMOPOUCH";
		Inventory.PickupSound "weapons/pocket";
		scale 0.6;

		hdweapon.wornlayer 0;
		hdweapon.refid UAS_HDLD_AMMOPOUCH;

		HDStorageItem.MinBulk 20;
		HDStorageItem.MaxCapacity 200;
		HDStorageItem.MaxBunch 20;
	}

	override bool IsBeingWorn() { return false; }

	override double WeaponBulk() {
		return ContainerBulk(itemBulk);
	}

	override double ContainerBulk(double it) const {
		let numPouches = max(weaponStatus[APS_AMOUNT], 1);
		let calcAmount = min(numPouches, 5);
		let reductionFactor = 0.45 + min(0.05 * calcAmount, 0.5);

		return max(it * reductionFactor, minBulk * numPouches);
	}

	override void BeginPlay() {
		super.BeginPlay();

		weaponStatus[APS_AMOUNT] = max(weaponStatus[APS_AMOUNT], 1);
	}

	override void PostBeginPlay() {
		super.PostBeginPlay();

		weaponStatus[APS_AMOUNT] = max(weaponStatus[APS_AMOUNT], 1);
	}

	override bool CanFitInThisContainer(Class<Inventory> itemType) {
		return itemType && (itemType  is 'HDRoundAmmo' || itemType is 'FourMilAmmo');
	}

	override bool ThisCanFitInThisContainer(Inventory item) {
		return item && (item  is 'HDRoundAmmo' || item is 'FourMilAmmo');
	}

	override void actualpickup(actor other, bool silent) {
		let HeldPouch = UaS_AmmoPouch(other.findinventory("UaS_AmmoPouch"));
		if (HeldPouch)
		{
			HeldPouch.weaponStatus[APS_AMOUNT]++;
			HeldPouch.maxCapacity = HeldPouch.weaponStatus[APS_AMOUNT] * HeldPouch.default.maxCapacity;

			while (items.size())
			{

				string itemCls, prefix;
				[itemCls, prefix] = itemClassAndPrefix(0);

				let amt = count(itemCls);
				HeldPouch.insert(extract(0, amt), amt);
			}

			destroy();
			return;
		}

		super.actualpickup(other, silent);
	}

	override inventory CreateTossable(int amt) {
		amount = weaponStatus[APS_AMOUNT]; // Hack to satisfy CreateTossable expectations

		let DroppedPouch = UaS_AmmoPouch(super.CreateTossable(amt));

		if (DroppedPouch && weaponStatus[APS_AMOUNT] > 1)
		{
			let bulkRatio = itemBulk / (maxCapacity * 1.0);
			weaponStatus[APS_AMOUNT]--;
			maxCapacity = weaponStatus[APS_AMOUNT] * default.maxCapacity;

			if (items.size() <= 0)
			{
				return DroppedPouch;
			}

			while (DroppedPouch.itemBulk / DroppedPouch.maxCapacity < bulkRatio)
			{
				string itemCls, prefix;
				[itemCls, prefix] = itemClassAndPrefix(0);

				if (itemCls)
				{
					double unitBulk = max(getDefaultByType((Class<HDPickup>)(itemCls)).bulk * HDMath.getEncumbranceMult(), Double.EPSILON);

					int amt = min((DroppedPouch.maxCapacity - DroppedPouch.itemBulk) / unitBulk, count(itemCls));
					DroppedPouch.insert(extract(0, amt), amt);
				}
			}
		}

		return DroppedPouch;
	}

	// Configure from Loadout
	override void LoadoutConfigure(string input) {
		super.LoadoutConfigure(input);

		int amt = input.ToInt();
		if (amt > 0)
		{
			weaponStatus[APS_AMOUNT] = amt;
		}
	}

