	States {
		Spawn:
			UGSP ABC -1 NoDelay
			{
				if (invoker.items.size() == 0)
				{
					frame = 1;
				}
				else if (target)
				{
					translation = target.translation;
					frame = 2;
				}

				invoker.bNO_AUTO_SWITCH = false;
			}
			Stop;
		User3:
			#### # 0 A_MagManager("");
			goto Ready;
	}
}

class UaS_AmmoPouchStorageItemList : HDStorageItemList {
	override bool CanAdd(Class<Inventory> itemCls)
	{
		return itemCls && (itemCls  is 'HDRoundAmmo' || itemCls is 'FourMilAmmo');
	}
}

class UaS_WildAmmoPouch : IdleDummy {
	override void postbeginplay() {
		super.postbeginplay();

		let SpawnedPouch = UaS_AmmoPouch(spawn("UaS_AmmoPouch", pos, ALLOW_REPLACE));
		SpawnedPouch.RandomContents("UaS_AmmoPouchStorageItemList", frandom(0.1, 0.5), false);

		HDF.TransferSpecials(self, SpawnedPouch);
		SpawnedPouch.vel = vel;

		destroy();
	}
}
